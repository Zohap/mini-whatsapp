<%- include("partials/header") %>

<div class="form-container">
    <form
action="/chats"
method="POST">

    <input
    type="text"
    name="from"
    placeholder="From"
    required>

    <input
    type="text"
    name="to"
    placeholder="To"
    required>

    <textarea
    name="msg"
    placeholder="Message"
    required></textarea>

    <button>
        Create Chat
    </button>

</form>

</div>
<%- include("partials/footer") %>